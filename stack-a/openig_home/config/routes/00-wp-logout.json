{
  "name": "00-wp-logout-intercept",
  "condition": "${matches(request.uri.path, '^/app1/wp-login[.]php$') and request.uri.query != null and matches(request.uri.query, '(^|&)action=logout($|&)')}",
  "handler": {
    "type": "ScriptableHandler",
    "config": {
      "type": "application/x-groovy",
      "file": "SloHandler.groovy"
    }
  }
}
