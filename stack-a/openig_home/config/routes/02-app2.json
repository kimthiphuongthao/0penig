{
  "name": "app2-whoami",
  "baseURI": "http://whoami",
  "condition": "${matches(request.headers['Host'][0], 'whoami-a.sso.local.*')}",
  "heap": [
    {
      "name": "KeycloakIssuer",
      "type": "Issuer",
      "config": {
        "issuer": "http://auth.sso.local:8080/realms/sso-realm",
        "authorizeEndpoint": "http://auth.sso.local:8080/realms/sso-realm/protocol/openid-connect/auth",
        "tokenEndpoint": "http://host.docker.internal:8080/realms/sso-realm/protocol/openid-connect/token",
        "userInfoEndpoint": "http://host.docker.internal:8080/realms/sso-realm/protocol/openid-connect/userinfo",
        "registrationEndpoint": "http://host.docker.internal:8080/realms/sso-realm/clients-registrations/openid-connect",
        "endSessionEndpoint": "http://auth.sso.local:8080/realms/sso-realm/protocol/openid-connect/logout"
      }
    },
    {
      "name": "OpenIGClientReg",
      "type": "ClientRegistration",
      "config": {
        "clientId": "openig-client",
        "clientSecret": "openig-client-secret",
        "issuer": "KeycloakIssuer",
        "scopes": [
          "openid",
          "profile",
          "email"
        ]
      }
    },
    {
      "name": "OidcFilter",
      "type": "OAuth2ClientFilter",
      "config": {
        "clientEndpoint": "/openid/app2",
        "requireHttps": false,
        "registrations": [
          "OpenIGClientReg"
        ],
        "scopes": [
          "openid",
          "profile",
          "email"
        ],
        "target": "${attributes.openid}",
        "defaultLogoutGoto": "http://auth.sso.local:8080/realms/sso-realm/protocol/openid-connect/logout?client_id=openig-client&post_logout_redirect_uri=http%3A%2F%2Fwhoami-a.sso.local%2F",
        "failureHandler": {
          "type": "StaticResponseHandler",
          "config": {
            "status": 500,
            "reason": "Internal Server Error",
            "headers": {
              "Content-Type": [
                "text/html"
              ]
            },
            "entity": "<html><body><h2>SSO authentication failed. Please contact support.</h2></body></html>"
          }
        }
      }
    },
    {
      "name": "App2HeaderFilter",
      "type": "HeaderFilter",
      "config": {
        "messageType": "REQUEST",
        "add": {
          "X-Authenticated-User": [
            "${attributes.openid != null && attributes.openid['user_info'] != null && attributes.openid['user_info']['preferred_username'] != null ? attributes.openid['user_info']['preferred_username'] : 'anonymous'}"
          ],
          "X-OpenIG-Node": [
            "${env['OPENIG_NODE_NAME'] != null ? env['OPENIG_NODE_NAME'] : 'unknown'}"
          ]
        }
      }
    },
    {
      "name": "SessionBlacklistFilterApp2",
      "type": "ScriptableFilter",
      "config": {
        "type": "application/x-groovy",
        "file": "SessionBlacklistFilterApp2.groovy"
      }
    },
    {
      "name": "App2PathStripper",
      "type": "ScriptableFilter",
      "config": {
        "type": "application/x-groovy",
        "source": "def path = request.uri.path ?: '/'\nif (path.startsWith('/app2')) {\n    def newPath = path.substring(5)\n    if (newPath.isEmpty()) {\n        newPath = '/'\n    } else if (!newPath.startsWith('/')) {\n        newPath = '/' + newPath\n    }\n    request.uri.path = newPath\n}\nreturn next.handle(context, request)"
      }
    },
    {
      "name": "App2Proxy",
      "type": "ClientHandler",
      "config": {
        "soTimeout": "10 seconds"
      }
    }
  ],
  "handler": {
    "type": "Chain",
    "config": {
      "filters": [
        "OidcFilter",
        "SessionBlacklistFilterApp2",
        "App2HeaderFilter"
      ],
      "handler": "App2Proxy"
    }
  }
}
