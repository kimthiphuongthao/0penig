# PRODUCTION: use K8s Secret -> envFrom secretRef
# kubectl create secret generic stack-a-secrets --from-env-file=.env
JWT_SHARED_SECRET=<shared secret for OpenIG JwtSession across nodes>
KEYSTORE_PASSWORD=<password for the OpenIG keystore>
OIDC_CLIENT_SECRET=<OIDC client secret for OpenIG>
MYSQL_ROOT_PASSWORD=<MySQL root password>
WORDPRESS_DB_PASSWORD=<WordPress database password>
REDIS_PASSWORD=<generate-strong-password>
