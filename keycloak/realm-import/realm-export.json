{
  "realm": "sso-realm",
  "enabled": true,
  "displayName": "SSO Lab Realm",
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": false,
  "clients": [
    {
      "clientId": "openig-client",
      "name": "OpenIG SSO Gateway",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "openig-client-secret",
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "http://openiga.sso.local/openid/*",
        "http://openiga.sso.local:80/openid/*",
        "http://localhost/openid/*"
      ],
      "webOrigins": [
        "http://localhost"
      ],
      "defaultClientScopes": [
        "web-origins",
        "acr",
        "profile",
        "roles",
        "email"
      ],
      "optionalClientScopes": [
        "address",
        "phone",
        "offline_access",
        "microprofile-jwt"
      ],
      "attributes": {
        "post.logout.redirect.uris": "http://localhost/##http://localhost/wp-admin/##http://localhost/app2/"
      }
    },
    {
      "clientId": "openig-client-b",
      "name": "OpenIG Client B",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "openig-client-b-secret",
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "http://openigb.sso.local:9080/openid/*",
        "http://localhost:9080/openid/*"
      ],
      "webOrigins": [
        "http://localhost:9080"
      ],
      "defaultClientScopes": [
        "web-origins",
        "acr",
        "profile",
        "roles",
        "email"
      ],
      "optionalClientScopes": [
        "address",
        "phone",
        "offline_access",
        "microprofile-jwt"
      ],
      "attributes": {
        "post.logout.redirect.uris": "http://localhost/##http://localhost/wp-admin/##http://localhost/app2/"
      }
    }
  ],
  "users": [
    {
      "username": "alice",
      "email": "alice@lab.local",
      "firstName": "Alice",
      "lastName": "Lab",
      "enabled": true,
      "credentials": [
        {
          "type": "password",
          "value": "alice123",
          "temporary": false
        }
      ]
    },
    {
      "username": "bob",
      "email": "bob@lab.local",
      "firstName": "Bob",
      "lastName": "Lab",
      "enabled": true,
      "credentials": [
        {
          "type": "password",
          "value": "bob123",
          "temporary": false
        }
      ]
    }
  ]
}