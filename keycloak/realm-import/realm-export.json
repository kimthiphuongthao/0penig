{
  "realm": "sso-realm",
  "enabled": true,
  "displayName": "SSO Lab Realm",
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": false,
  "clients": [
    {
      "clientId": "openig-client",
      "name": "OpenIG SSO Gateway",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "openig-client-secret",
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "http://openiga.sso.local/openid/*",
        "http://openiga.sso.local:80/openid/*",
        "http://localhost/openid/*"
      ],
      "webOrigins": [
        "http://localhost"
      ],
      "defaultClientScopes": [
        "web-origins",
        "acr",
        "profile",
        "roles",
        "email"
      ],
      "optionalClientScopes": [
        "address",
        "phone",
        "offline_access",
        "microprofile-jwt"
      ],
      "attributes": {
        "post.logout.redirect.uris": "http://openiga.sso.local/app1/##http://openiga.sso.local/app2/##http://localhost/app1/##http://localhost/app2/",
        "backchannel.logout.url": "http://host.docker.internal/openid/app1/backchannel_logout",
        "backchannel.logout.session.required": "true"
      }
    },
    {
      "clientId": "openig-client-b",
      "name": "OpenIG Client B",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "openig-client-b-secret",
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "http://openigb.sso.local:9080/openid/*",
        "http://localhost:9080/openid/*"
      ],
      "webOrigins": [
        "http://localhost:9080"
      ],
      "defaultClientScopes": [
        "web-origins",
        "acr",
        "profile",
        "roles",
        "email"
      ],
      "optionalClientScopes": [
        "address",
        "phone",
        "offline_access",
        "microprofile-jwt"
      ],
      "attributes": {
        "post.logout.redirect.uris": "http://openigb.sso.local:9080/app3/##http://openigb.sso.local:9080/app4/##http://localhost:9080/app3/##http://localhost:9080/app4/",
        "backchannel.logout.url": "http://host.docker.internal:9080/openid/app3/backchannel_logout",
        "backchannel.logout.session.required": "true"
      }
      },
      {
        "clientId": "openig-client-b-app4",
        "name": "OpenIG Client B App4",
        "enabled": true,
        "protocol": "openid-connect",
        "publicClient": false,
        "secret": "openig-client-b-app4-secret",
        "standardFlowEnabled": true,
        "implicitFlowEnabled": false,
        "directAccessGrantsEnabled": false,
        "serviceAccountsEnabled": false,
        "redirectUris": [
          "http://jellyfin-b.sso.local:9080/openid/app4/*",
          "http://jellyfin-b.sso.local/openid/app4/*",
          "http://localhost:9080/openid/app4/*"
        ],
        "webOrigins": [
          "http://jellyfin-b.sso.local:9080",
          "http://jellyfin-b.sso.local",
          "http://localhost:9080"
        ],
        "defaultClientScopes": [
          "web-origins",
          "acr",
          "profile",
          "roles",
          "email"
        ],
        "optionalClientScopes": [
          "address",
          "phone",
          "offline_access",
          "microprofile-jwt"
        ],
        "attributes": {
          "post.logout.redirect.uris": "http://jellyfin-b.sso.local:9080/##http://jellyfin-b.sso.local/",
          "backchannel.logout.url": "http://host.docker.internal:9080/openid/app4/backchannel_logout",
          "backchannel.logout.session.required": "true",
          "backchannel.logout.revoke.offline.tokens": "false"
        }
      },
      {
        "clientId": "openig-client-c-app5",
        "name": "OpenIG Client C App5",
        "enabled": true,
        "protocol": "openid-connect",
        "publicClient": false,
        "secret": "secret-c",
        "standardFlowEnabled": true,
        "implicitFlowEnabled": false,
        "directAccessGrantsEnabled": false,
        "serviceAccountsEnabled": false,
        "redirectUris": [
          "http://grafana-c.sso.local:18080/openid/app5/*"
        ],
        "webOrigins": [
          "http://grafana-c.sso.local:18080"
        ],
        "defaultClientScopes": [
