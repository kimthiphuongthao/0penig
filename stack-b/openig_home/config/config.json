{
  "heap": [
    {
      "name": "Router",
      "type": "Router",
      "config": {
        "directory": "/opt/openig/config/routes"
      }
    },
    {
      "name": "JwtKeyStore",
      "type": "KeyStore",
      "config": {
        "url": "file:///opt/openig/keystore.p12",
        "password": "__KEYSTORE_PASSWORD__",
        "type": "PKCS12"
      }
    },
    {
      "name": "Session",
      "type": "JwtSession",
      "config": {
        "cookieName": "IG_SSO_B",
        "cookieDomain": ".sso.local",
        "sessionTimeout": "30 minutes",
        "sharedSecret": "__JWT_SHARED_SECRET__",
        "keystore": "JwtKeyStore",
        "alias": "openig-jwt",
        "password": "__KEYSTORE_PASSWORD__"
      }
    }
  ],
  "handler": "Router"
}
