{
  "name": "00-dotnet-logout-intercept",
  "condition": "${matches(request.headers['Host'][0], 'openigb.sso.local.*') and matches(request.uri.path, '^/app3/Account/Logout')}",
  "handler": {
    "type": "ScriptableHandler",
    "config": {
      "type": "application/x-groovy",
      "file": "DotnetSloHandler.groovy"
    }
  }
}
