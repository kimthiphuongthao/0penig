{
  "name": "phpmyadmin-sso",
  "baseURI": "http://phpmyadmin:80",
  "condition": "${matches(request.headers['Host'][0], 'phpmyadmin-c.sso.local.*') and not(matches(request.uri.path, '^/openid/app6/backchannel_logout$'))}",
  "heap": [
    {
      "name": "KeycloakIssuer",
      "type": "Issuer",
      "config": {
        "issuer": "${env['KEYCLOAK_BROWSER_URL']}/realms/sso-realm",
        "authorizeEndpoint": "${env['KEYCLOAK_BROWSER_URL']}/realms/sso-realm/protocol/openid-connect/auth",
        "tokenEndpoint": "${env['KEYCLOAK_INTERNAL_URL']}/realms/sso-realm/protocol/openid-connect/token",
        "userInfoEndpoint": "${env['KEYCLOAK_INTERNAL_URL']}/realms/sso-realm/protocol/openid-connect/userinfo",
        "jwksUri": "${env['KEYCLOAK_INTERNAL_URL']}/realms/sso-realm/protocol/openid-connect/certs"
      }
    },
    {
      "name": "PhpMyAdminClientReg",
      "type": "ClientRegistration",
      "config": {
        "clientId": "openig-client-c-app6",
        "clientSecret": "${env['OIDC_CLIENT_SECRET_APP6']}",
        "issuer": "KeycloakIssuer",
        "scopes": [
          "openid",
          "profile",
          "email"
        ]
      }
    },
    {
      "name": "OidcFilterApp6",
      "type": "OAuth2ClientFilter",
      "config": {
        "clientEndpoint": "/openid/app6",
        "registrations": [
          "PhpMyAdminClientReg"
        ],
        "scopes": [
          "openid",
          "profile",
          "email"
        ],
        "requireHttps": false,
        "target": "${attributes.openid}",
        "failureHandler": {
          "type": "StaticResponseHandler",
          "config": {
            "status": 500,
            "reason": "Internal Server Error",
            "headers": {
              "Content-Type": [
                "text/html"
              ]
            },
            "entity": "<html><body><h2>SSO authentication failed. Please contact support.</h2></body></html>"
          }
        }
      }
    },
    {
      "name": "SessionBlacklistFilterApp6",
      "type": "ScriptableFilter",
      "config": {
        "type": "application/x-groovy",
        "file": "SessionBlacklistFilter.groovy",
        "args": {
          "clientEndpoint": "/openid/app6",
          "sessionCacheKey": "oidc_sid_app6",
          "canonicalOrigin": "http://phpmyadmin-c.sso.local:18080",
          "canonicalOriginEnvVar": "CANONICAL_ORIGIN_APP6"
        }
      }
    },
    {
      "name": "VaultCredentialFilter",
      "type": "ScriptableFilter",
      "config": {
        "type": "application/x-groovy",
        "file": "VaultCredentialFilter.groovy"
      }
    },
    {
      "name": "PhpMyAdminBasicAuth",
      "type": "HttpBasicAuthFilter",
      "config": {
        "username": "${attributes.phpmyadmin_username}",
        "password": "${attributes.phpmyadmin_password}",
        "cacheHeader": false,
        "failureHandler": {
          "type": "ScriptableHandler",
          "config": {
            "type": "application/x-groovy",
            "file": "SloHandler.groovy",
            "args": {
              "clientEndpoint": "/openid/app6",
              "clientId": "openig-client-c-app6",
              "canonicalOrigin": "http://phpmyadmin-c.sso.local:18080",
              "postLogoutPath": "/"
            }
          }
        }
      }
    },
    {
      "name": "PhpMyAdminProxy",
      "type": "ClientHandler",
      "config": {
        "soTimeout": "10 seconds"
      }
    }
  ],
  "handler": {
    "type": "Chain",
    "config": {
      "filters": [
        "OidcFilterApp6",
        "SessionBlacklistFilterApp6",
        "VaultCredentialFilter",
        "PhpMyAdminBasicAuth"
      ],
      "handler": "PhpMyAdminProxy"
    }
  }
}
