{
  "name": "grafana-sso",
  "baseURI": "http://grafana:3000",
  "condition": "${matches(request.headers['Host'][0], 'grafana-c.sso.local.*') and not(matches(request.uri.path, '^/openid/app5/backchannel_logout$'))}",
  "heap": [
    {
      "name": "KeycloakIssuer",
      "type": "Issuer",
      "config": {
        "issuer": "http://auth.sso.local:8080/realms/sso-realm",
        "authorizeEndpoint": "http://auth.sso.local:8080/realms/sso-realm/protocol/openid-connect/auth",
        "tokenEndpoint": "http://host.docker.internal:8080/realms/sso-realm/protocol/openid-connect/token",
        "userInfoEndpoint": "http://host.docker.internal:8080/realms/sso-realm/protocol/openid-connect/userinfo",
        "registrationEndpoint": "http://host.docker.internal:8080/realms/sso-realm/clients-registrations/openid-connect",
        "endSessionEndpoint": "http://auth.sso.local:8080/realms/sso-realm/protocol/openid-connect/logout"
      }
    },
    {
      "name": "GrafanaClientReg",
      "type": "ClientRegistration",
      "config": {
        "clientId": "openig-client-c-app5",
        "clientSecret": "${env['OIDC_CLIENT_SECRET_APP5']}",
        "issuer": "KeycloakIssuer",
        "scopes": [
          "openid",
          "profile",
          "email"
        ]
      }
    },
    {
      "name": "OidcFilterApp5",
      "type": "OAuth2ClientFilter",
      "config": {
        "clientEndpoint": "/openid/app5",
        "registrations": [
          "GrafanaClientReg"
        ],
        "scopes": [
          "openid",
          "profile",
          "email"
        ],
        "requireHttps": false,
        "target": "${attributes.openid}",
        "defaultLogoutGoto": "http://auth.sso.local:8080/realms/sso-realm/protocol/openid-connect/logout?client_id=openig-client-c-app5&post_logout_redirect_uri=http%3A%2F%2Fgrafana-c.sso.local%3A18080%2F",
        "failureHandler": {
          "type": "StaticResponseHandler",
          "config": {
            "status": 500,
            "reason": "Internal Server Error",
            "headers": {
              "Content-Type": [
                "text/html"
              ]
            },
            "entity": "<html><body><h2>SSO authentication failed. Please contact support.</h2></body></html>"
          }
        }
      }
    },
    {
      "name": "SessionBlacklistFilterApp5",
      "type": "ScriptableFilter",
      "config": {
        "type": "application/x-groovy",
        "file": "SessionBlacklistFilter.groovy",
        "args": {
          "clientEndpoint": "/openid/app5",
          "sessionCacheKey": "oidc_sid_app5",
          "canonicalOrigin": "http://grafana-c.sso.local:18080",
          "canonicalOriginEnvVar": "CANONICAL_ORIGIN_APP5"
        }
      }
    },
    {
      "name": "GrafanaUserHeader",
      "type": "HeaderFilter",
      "config": {
        "messageType": "REQUEST",
        "remove": [
          "X-WEBAUTH-USER"
        ],
        "add": {
          "X-WEBAUTH-USER": [
            "${attributes.openid['user_info']['preferred_username']}"
          ]
        }
      }
    },
    {
      "name": "GrafanaProxy",
      "type": "ClientHandler",
      "config": {
        "soTimeout": "10 seconds"
      }
    }
  ],
  "handler": {
    "type": "Chain",
    "config": {
      "filters": [
        "OidcFilterApp5",
        "SessionBlacklistFilterApp5",
        "GrafanaUserHeader"
      ],
      "handler": "GrafanaProxy"
    }
  }
}
