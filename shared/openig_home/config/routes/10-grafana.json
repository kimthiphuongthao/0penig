{
  "name": "grafana-sso",
  "baseURI": "http://shared-grafana:3000",
  "condition": "${matches(request.headers['Host'][0], 'grafana-c.sso.local.*') and not(matches(request.uri.path, '^/openid/app5/backchannel_logout$'))}",
  "session": "SessionApp5",
  "heap": [
    {
      "name": "KeycloakIssuer",
      "type": "Issuer",
      "config": {
        "issuer": "${env['KEYCLOAK_BROWSER_URL']}/realms/sso-realm",
        "authorizeEndpoint": "${env['KEYCLOAK_BROWSER_URL']}/realms/sso-realm/protocol/openid-connect/auth",
        "tokenEndpoint": "${env['KEYCLOAK_INTERNAL_URL']}/realms/sso-realm/protocol/openid-connect/token",
        "userInfoEndpoint": "${env['KEYCLOAK_INTERNAL_URL']}/realms/sso-realm/protocol/openid-connect/userinfo",
        "jwksUri": "${env['KEYCLOAK_INTERNAL_URL']}/realms/sso-realm/protocol/openid-connect/certs"
      }
    },
    {
      "name": "GrafanaClientReg",
      "type": "ClientRegistration",
      "config": {
        "clientId": "openig-client-c-app5",
        "clientSecret": "${env['OIDC_CLIENT_SECRET_APP5']}",
        "issuer": "KeycloakIssuer",
        "scopes": [
          "openid",
          "profile",
          "email"
        ]
      }
    },
    {
      "name": "SessionApp5",
      "type": "JwtSession",
      "config": {
        "cookieName": "IG_SSO_APP5",
        "sessionTimeout": "30 minutes",
        "sharedSecret": "${env['JWT_SHARED_SECRET']}",
        "keystore": "JwtKeyStore",
        "alias": "openig-jwt",
        "password": "${env['KEYSTORE_PASSWORD']}"
      }
    },
    {
      "name": "OidcFilterApp5",
      "type": "OAuth2ClientFilter",
      "config": {
        "clientEndpoint": "/openid/app5",
        "registrations": [
          "GrafanaClientReg"
        ],
        "scopes": [
          "openid",
          "profile",
          "email"
        ],
        "requireHttps": false,
        "target": "${attributes.openid}",
        "failureHandler": {
          "type": "StaticResponseHandler",
          "config": {
            "status": 500,
            "reason": "Internal Server Error",
            "headers": {
              "Content-Type": [
                "text/html"
              ]
            },
            "entity": "<html><body><h2>SSO authentication failed. Please contact support.</h2></body></html>"
          }
        }
      }
    },
    {
      "name": "SpaBlacklistGuardApp5",
      "type": "ScriptableFilter",
      "config": {
        "type": "application/x-groovy",
        "file": "SpaBlacklistGuardFilter.groovy",
        "args": {
          "sessionCacheKey": "oidc_sid_app5",
          "redisHost": "shared-redis",
          "redisPort": "${env['REDIS_PORT'] != null ? env['REDIS_PORT'] : '6379'}",
          "redisAuth": "${env['REDIS_PASSWORD_APP5'] != null ? env['REDIS_PASSWORD_APP5'] : ''}",
          "redisUser": "openig-app5",
          "redisPasswordEnvVar": "REDIS_PASSWORD_APP5",
          "redisKeyPrefix": "app5"
        }
      }
    },
    {
      "name": "TokenReferenceFilterApp5",
      "type": "ScriptableFilter",
      "config": {
        "type": "application/x-groovy",
        "file": "TokenReferenceFilter.groovy",
        "args": {
          "clientEndpoint": "/openid/app5",
          "redisHost": "shared-redis",
          "redisTtl": 1800,
          "tokenRefKey": "token_ref_id_app5",
          "sessionCacheKey": "oidc_sid_app5",
          "redisUser": "openig-app5",
          "redisPasswordEnvVar": "REDIS_PASSWORD_APP5",
          "redisKeyPrefix": "app5"
        }
      }
    },
    {
      "name": "SpaAuthGuardApp5",
      "type": "ScriptableFilter",
      "config": {
        "type": "application/x-groovy",
        "file": "SpaAuthGuardFilter.groovy",
        "args": {
          "clientEndpoint": "/openid/app5",
          "tokenRefKey": "token_ref_id_app5"
        }
      }
    },
    {
      "name": "SessionBlacklistFilterApp5",
      "type": "ScriptableFilter",
      "config": {
        "type": "application/x-groovy",
        "file": "SessionBlacklistFilter.groovy",
        "args": {
          "clientEndpoint": "/openid/app5",
          "sessionCacheKey": "oidc_sid_app5",
          "canonicalOrigin": "http://grafana-c.sso.local",
          "canonicalOriginEnvVar": "CANONICAL_ORIGIN_APP5",
          "redisUser": "openig-app5",
          "redisPasswordEnvVar": "REDIS_PASSWORD_APP5",
          "redisKeyPrefix": "app5"
        }
      }
    },
    {
      "name": "StripGatewaySessionCookiesApp5",
      "type": "ScriptableFilter",
      "config": {
        "type": "application/x-groovy",
        "file": "StripGatewaySessionCookies.groovy"
      }
    },
    {
      "name": "GrafanaUserHeader",
      "type": "HeaderFilter",
      "config": {
        "messageType": "REQUEST",
        "remove": [
          "X-WEBAUTH-USER"
        ],
        "add": {
          "X-WEBAUTH-USER": [
            "${attributes.openid['user_info']['preferred_username']}"
          ]
        }
      }
    },
    {
      "name": "GrafanaProxy",
      "type": "ClientHandler",
      "config": {
        "soTimeout": "10 seconds"
      }
    }
  ],
  "handler": {
    "type": "Chain",
    "config": {
      "filters": [
        "SpaBlacklistGuardApp5",
        "TokenReferenceFilterApp5",
        "SpaAuthGuardApp5",
        "OidcFilterApp5",
        "SessionBlacklistFilterApp5",
        "StripGatewaySessionCookiesApp5",
        "GrafanaUserHeader"
      ],
      "handler": "GrafanaProxy"
    }
  }
}
