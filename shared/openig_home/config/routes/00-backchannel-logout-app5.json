{
  "name": "00-backchannel-logout-app5",
  "condition": "${matches(request.uri.path, '^/openid/app5/backchannel_logout$') and request.method == 'POST'}",
  "handler": {
    "type": "ScriptableHandler",
    "config": {
      "type": "application/x-groovy",
      "file": "BackchannelLogoutHandler.groovy",
      "args": {
        "audiences": [
          "openig-client-c-app5"
        ],
        "redisHost": "shared-redis",
        "jwksUri": "${env['KEYCLOAK_INTERNAL_URL']}/realms/sso-realm/protocol/openid-connect/certs",
        "issuer": "${env['KEYCLOAK_BROWSER_URL']}/realms/sso-realm",
        "ttlSeconds": "${env['REDIS_BLACKLIST_TTL_APP5'] != null ? env['REDIS_BLACKLIST_TTL_APP5'] : '28800'}",
        "redisUser": "openig-app5",
        "redisPasswordEnvVar": "REDIS_PASSWORD_APP5",
        "redisKeyPrefix": "app5"
      }
    }
  }
}
