{
  "name": "00-backchannel-logout-app4",
  "condition": "${matches(request.uri.path, '^/openid/app4/backchannel_logout$') and request.method == 'POST'}",
  "handler": {
    "type": "ScriptableHandler",
    "config": {
      "type": "application/x-groovy",
      "file": "BackchannelLogoutHandler.groovy",
      "args": {
        "audiences": [
          "openig-client-b-app4"
        ],
        "redisHost": "shared-redis",
        "jwksUri": "http://host.docker.internal:8080/realms/sso-realm/protocol/openid-connect/certs",
        "issuer": "http://auth.sso.local:8080/realms/sso-realm",
        "ttlSeconds": "${env['REDIS_BLACKLIST_TTL'] != null ? env['REDIS_BLACKLIST_TTL'] : '28800'}",
        "redisUser": "openig-app4",
        "redisPasswordEnvVar": "REDIS_PASSWORD_APP4",
        "redisKeyPrefix": "app4"
      }
    }
  }
}
