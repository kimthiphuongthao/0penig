{
  "name": "app2-whoami",
  "baseURI": "http://shared-whoami",
  "condition": "${matches(request.headers['Host'][0], 'whoami-a.sso.local.*')}",
  "session": "SessionApp2",
  "heap": [
    {
      "name": "KeycloakIssuer",
      "type": "Issuer",
      "config": {
        "issuer": "${env['KEYCLOAK_BROWSER_URL']}/realms/sso-realm",
        "authorizeEndpoint": "${env['KEYCLOAK_BROWSER_URL']}/realms/sso-realm/protocol/openid-connect/auth",
        "tokenEndpoint": "${env['KEYCLOAK_INTERNAL_URL']}/realms/sso-realm/protocol/openid-connect/token",
        "userInfoEndpoint": "${env['KEYCLOAK_INTERNAL_URL']}/realms/sso-realm/protocol/openid-connect/userinfo",
        "jwksUri": "${env['KEYCLOAK_INTERNAL_URL']}/realms/sso-realm/protocol/openid-connect/certs"
      }
    },
    {
      "name": "OpenIGClientReg",
      "type": "ClientRegistration",
      "config": {
        "clientId": "openig-client",
        "clientSecret": "${env['OIDC_CLIENT_SECRET']}",
        "issuer": "KeycloakIssuer",
        "scopes": [
          "openid",
          "profile",
          "email"
        ]
      }
    },
    {
      "name": "SessionApp2",
      "type": "JwtSession",
      "config": {
        "cookieName": "IG_SSO_APP2",
        "sessionTimeout": "30 minutes",
        "sharedSecret": "${env['JWT_SHARED_SECRET']}",
        "keystore": "JwtKeyStore",
        "alias": "openig-jwt",
        "password": "${env['KEYSTORE_PASSWORD']}"
      }
    },
    {
      "name": "OidcFilter",
      "type": "OAuth2ClientFilter",
      "config": {
        "clientEndpoint": "/openid/app2",
        "requireHttps": false,
        "registrations": [
          "OpenIGClientReg"
        ],
        "scopes": [
          "openid",
          "profile",
          "email"
        ],
        "target": "${attributes.openid}",
        "failureHandler": {
          "type": "StaticResponseHandler",
          "config": {
            "status": 500,
            "reason": "Internal Server Error",
            "headers": {
              "Content-Type": [
                "text/html"
              ]
            },
            "entity": "<html><body><h2>SSO authentication failed. Please contact support.</h2></body></html>"
          }
        }
      }
    },
    {
      "name": "TokenReferenceFilterApp2",
      "type": "ScriptableFilter",
      "config": {
        "type": "application/x-groovy",
        "file": "TokenReferenceFilter.groovy",
        "args": {
          "clientEndpoint": "/openid/app2",
          "redisHost": "shared-redis",
          "redisTtl": 1800,
          "tokenRefKey": "token_ref_id_app2",
          "redisUser": "openig-app2",
          "redisPasswordEnvVar": "REDIS_PASSWORD_APP2",
            "redisKeyPrefix": "app2",
            "transitKeyName": "app2-key",
            "appRoleName": "openig-app2",
            "vaultRoleIdFile": "/vault/file/openig-app2-role-id",
            "vaultSecretIdFile": "/vault/file/openig-app2-secret-id"
        }
      }
    },
    {
      "name": "App2HeaderFilter",
      "type": "HeaderFilter",
      "config": {
        "messageType": "REQUEST",
        "add": {
          "X-Authenticated-User": [
            "${attributes.openid != null && attributes.openid['user_info'] != null && attributes.openid['user_info']['preferred_username'] != null ? attributes.openid['user_info']['preferred_username'] : 'anonymous'}"
          ],
          "X-OpenIG-Node": [
            "${env['OPENIG_NODE_NAME'] != null ? env['OPENIG_NODE_NAME'] : 'unknown'}"
          ]
        }
      }
    },
    {
      "name": "SessionBlacklistFilterApp2",
      "type": "ScriptableFilter",
      "config": {
        "type": "application/x-groovy",
        "file": "SessionBlacklistFilter.groovy",
        "args": {
          "clientEndpoint": "/openid/app2",
          "sessionCacheKey": "oidc_sid_app2",
          "canonicalOrigin": "http://whoami-a.sso.local",
          "canonicalOriginEnvVar": "CANONICAL_ORIGIN_APP2",
          "redisUser": "openig-app2",
          "redisPasswordEnvVar": "REDIS_PASSWORD_APP2",
          "redisKeyPrefix": "app2"
        }
      }
    },
    {
      "name": "StripGatewaySessionCookiesApp2",
      "type": "ScriptableFilter",
      "config": {
        "type": "application/x-groovy",
        "file": "StripGatewaySessionCookies.groovy"
      }
    },
    {
      "name": "App2Proxy",
      "type": "ClientHandler",
      "config": {
        "soTimeout": "10 seconds"
      }
    }
  ],
  "handler": {
    "type": "Chain",
    "config": {
      "filters": [
        "TokenReferenceFilterApp2",
        "OidcFilter",
        "SessionBlacklistFilterApp2",
        "StripGatewaySessionCookiesApp2",
        "App2HeaderFilter"
      ],
      "handler": "App2Proxy"
    }
  }
}
