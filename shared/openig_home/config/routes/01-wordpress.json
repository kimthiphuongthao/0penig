{
  "name": "wordpress-sso",
  "baseURI": "http://shared-wordpress",
  "condition": "${matches(request.headers['Host'][0], 'wp-a.sso.local.*')}",
  "session": "SessionApp1",
  "heap": [
    {
      "name": "KeycloakIssuer",
      "type": "Issuer",
      "config": {
        "issuer": "${env['KEYCLOAK_BROWSER_URL']}/realms/sso-realm",
        "authorizeEndpoint": "${env['KEYCLOAK_BROWSER_URL']}/realms/sso-realm/protocol/openid-connect/auth",
        "tokenEndpoint": "${env['KEYCLOAK_INTERNAL_URL']}/realms/sso-realm/protocol/openid-connect/token",
        "userInfoEndpoint": "${env['KEYCLOAK_INTERNAL_URL']}/realms/sso-realm/protocol/openid-connect/userinfo",
        "jwksUri": "${env['KEYCLOAK_INTERNAL_URL']}/realms/sso-realm/protocol/openid-connect/certs"
      }
    },
    {
      "name": "OpenIGClientReg",
      "type": "ClientRegistration",
      "config": {
        "clientId": "openig-client",
        "clientSecret": "${env['OIDC_CLIENT_SECRET']}",
        "issuer": "KeycloakIssuer",
        "scopes": [
          "openid",
          "profile",
          "email"
        ]
      }
    },
    {
      "name": "SessionApp1",
      "type": "JwtSession",
      "config": {
        "cookieName": "IG_SSO_APP1",
        "cookieDomain": ".sso.local",
        "sessionTimeout": "30 minutes",
        "sharedSecret": "${env['JWT_SHARED_SECRET']}",
        "keystore": "JwtKeyStore",
        "alias": "openig-jwt",
        "password": "${env['KEYSTORE_PASSWORD']}"
      }
    },
    {
      "name": "OidcFilter",
      "type": "OAuth2ClientFilter",
      "config": {
        "clientEndpoint": "/openid/app1",
        "requireHttps": false,
        "registrations": [
          "OpenIGClientReg"
        ],
        "scopes": [
          "openid",
          "profile",
          "email"
        ],
        "target": "${attributes.openid}",
        "failureHandler": {
          "type": "StaticResponseHandler",
          "config": {
            "status": 500,
            "reason": "Internal Server Error",
            "headers": {
              "Content-Type": [
                "text/html"
              ]
            },
            "entity": "<html><body><h2>SSO authentication failed. Please contact support.</h2></body></html>"
          }
        }
      }
    },
    {
      "name": "TokenReferenceFilterApp1",
      "type": "ScriptableFilter",
      "config": {
        "type": "application/x-groovy",
        "file": "TokenReferenceFilter.groovy",
        "args": {
          "clientEndpoint": "/openid/app1",
          "redisHost": "shared-redis",
          "redisTtl": 1800,
          "tokenRefKey": "token_ref_id_app1",
          "redisUser": "openig-app1",
          "redisPasswordEnvVar": "REDIS_PASSWORD_APP1",
          "redisKeyPrefix": "app1"
        }
      }
    },
    {
      "name": "VaultCredentialFilter",
      "type": "ScriptableFilter",
      "config": {
        "type": "application/x-groovy",
        "file": "VaultCredentialFilter.groovy",
        "args": {
          "appDisplayName": "WordPress",
          "secretPathPrefix": "wp-creds",
          "lookupUserInfoField": "preferred_username",
          "credentialAttributeName": "wp_credentials",
          "credentialUsernameSource": "secret",
          "credentialUsernameField": "username",
          "attributeUsernameField": "wp_username",
          "credentialPasswordField": "password",
          "attributePasswordField": "wp_password",
          "appRoleName": "openig-app1",
          "vaultRoleIdFile": "/vault/file/openig-app1-role-id",
          "vaultSecretIdFile": "/vault/file/openig-app1-secret-id"
        }
      }
    },
    {
      "name": "SessionBlacklistFilter",
      "type": "ScriptableFilter",
      "config": {
        "type": "application/x-groovy",
        "file": "SessionBlacklistFilter.groovy",
        "args": {
          "clientEndpoint": "/openid/app1",
          "sessionCacheKey": "oidc_sid",
          "canonicalOrigin": "http://wp-a.sso.local",
          "canonicalOriginEnvVar": "CANONICAL_ORIGIN_APP1",
          "redisUser": "openig-app1",
          "redisPasswordEnvVar": "REDIS_PASSWORD_APP1",
          "redisKeyPrefix": "app1"
        }
      }
    },
    {
      "name": "StripGatewaySessionCookiesApp1",
      "type": "ScriptableFilter",
      "config": {
        "type": "application/x-groovy",
        "file": "StripGatewaySessionCookies.groovy"
      }
    },
    {
      "name": "WpSessionInjector",
      "type": "ScriptableFilter",
      "config": {
        "type": "application/x-groovy",
        "file": "CredentialInjector.groovy"
      }
    },
    {
      "name": "WordPressProxy",
      "type": "ClientHandler",
      "config": {
        "soTimeout": "10 seconds"
      }
    }
  ],
  "handler": {
    "type": "Chain",
    "config": {
      "filters": [
        "TokenReferenceFilterApp1",
        "OidcFilter",
        "SessionBlacklistFilter",
        "StripGatewaySessionCookiesApp1",
        "VaultCredentialFilter",
        "WpSessionInjector"
      ],
      "handler": "WordPressProxy"
    }
  }
}
