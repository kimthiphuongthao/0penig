{
  "name": "redmine-sso",
  "baseURI": "http://shared-redmine:3000",
  "condition": "${matches(request.headers['Host'][0], 'redmine-b.sso.local.*') and not(matches(request.uri.path, '^/openig.*'))}",
  "session": "SessionApp3",
  "heap": [
    {
      "name": "KeycloakIssuer",
      "type": "Issuer",
      "config": {
        "issuer": "${env['KEYCLOAK_BROWSER_URL']}/realms/sso-realm",
        "authorizeEndpoint": "${env['KEYCLOAK_BROWSER_URL']}/realms/sso-realm/protocol/openid-connect/auth",
        "tokenEndpoint": "${env['KEYCLOAK_INTERNAL_URL']}/realms/sso-realm/protocol/openid-connect/token",
        "userInfoEndpoint": "${env['KEYCLOAK_INTERNAL_URL']}/realms/sso-realm/protocol/openid-connect/userinfo",
        "jwksUri": "${env['KEYCLOAK_INTERNAL_URL']}/realms/sso-realm/protocol/openid-connect/certs"
      }
    },
    {
      "name": "RedmineClientReg",
      "type": "ClientRegistration",
      "config": {
        "clientId": "openig-client-b",
        "clientSecret": "${env['OIDC_CLIENT_SECRET_B']}",
        "issuer": "KeycloakIssuer",
        "scopes": [
          "openid",
          "profile",
          "email"
        ],
        "tokenEndpointAuthMethod": "client_secret_post"
      }
    },
    {
      "name": "SessionApp3",
      "type": "JwtSession",
      "config": {
        "cookieName": "IG_SSO_APP3",
        "sessionTimeout": "30 minutes",
        "sharedSecret": "${env['JWT_SHARED_SECRET']}",
        "keystore": "JwtKeyStore",
        "alias": "openig-jwt",
        "password": "${env['KEYSTORE_PASSWORD']}"
      }
    },
    {
      "name": "SSOFailureHandler",
      "type": "StaticResponseHandler",
      "config": {
        "status": 502,
        "headers": {
          "Content-Type": [
            "text/html"
          ]
        },
        "entity": "<html><body><h2>SSO authentication failed. Please contact support.</h2></body></html>"
      }
    },
    {
      "name": "ClientHandler",
      "type": "ClientHandler"
    },
    {
      "name": "RedmineProxy",
      "type": "ClientHandler",
      "config": {
        "soTimeout": "10 seconds"
      }
    },
    {
      "name": "TokenReferenceFilterApp3",
      "type": "ScriptableFilter",
      "config": {
        "type": "application/x-groovy",
        "file": "TokenReferenceFilter.groovy",
        "args": {
          "clientEndpoint": "/openid/app3",
          "redisHost": "shared-redis",
          "redisTtl": 1800,
          "tokenRefKey": "token_ref_id_app3",
          "redisUser": "openig-app3",
          "redisPasswordEnvVar": "REDIS_PASSWORD_APP3",
          "redisKeyPrefix": "app3"
        }
      }
    },
    {
      "name": "SessionBlacklistFilterApp3",
      "type": "ScriptableFilter",
      "config": {
        "type": "application/x-groovy",
        "file": "SessionBlacklistFilter.groovy",
        "args": {
          "clientEndpoint": "/openid/app3",
          "sessionCacheKey": "oidc_sid_app3",
          "canonicalOrigin": "http://redmine-b.sso.local",
          "canonicalOriginEnvVar": "CANONICAL_ORIGIN_APP3",
          "redisUser": "openig-app3",
          "redisPasswordEnvVar": "REDIS_PASSWORD_APP3",
          "redisKeyPrefix": "app3"
        }
      }
    },
    {
      "name": "StripGatewaySessionCookiesApp3",
      "type": "ScriptableFilter",
      "config": {
        "type": "application/x-groovy",
        "file": "StripGatewaySessionCookies.groovy"
      }
    },
    {
      "name": "VaultCredentialFilterRedmine",
      "type": "ScriptableFilter",
      "config": {
        "type": "application/x-groovy",
        "file": "VaultCredentialFilter.groovy",
        "args": {
          "appDisplayName": "Redmine",
          "secretPathPrefix": "redmine-creds",
          "lookupUserInfoField": "email",
          "credentialAttributeName": "redmine_credentials",
          "credentialUsernameSource": "secret",
          "credentialUsernameField": "login",
          "attributeUsernameField": "login",
          "credentialPasswordField": "password",
          "attributePasswordField": "password",
          "appRoleName": "openig-app3",
          "vaultRoleIdFile": "/vault/file/openig-app3-role-id",
          "vaultSecretIdFile": "/vault/file/openig-app3-secret-id"
        }
      }
    },
    {
      "name": "RedmineCredentialInjectorFilter",
      "type": "ScriptableFilter",
      "config": {
        "type": "application/x-groovy",
        "file": "RedmineCredentialInjector.groovy"
      }
    }
  ],
  "handler": {
    "type": "Chain",
    "config": {
      "filters": [
        "TokenReferenceFilterApp3",
        {
          "type": "OAuth2ClientFilter",
          "config": {
            "clientEndpoint": "/openid/app3",
            "requireHttps": false,
            "registrations": [
              "RedmineClientReg"
            ],
            "scopes": [
              "openid",
              "profile",
              "email"
            ],
            "target": "${attributes.openid}",
            "failureHandler": "SSOFailureHandler",
            "providerHandler": "ClientHandler"
          }
        },
        "SessionBlacklistFilterApp3",
        "StripGatewaySessionCookiesApp3",
        "VaultCredentialFilterRedmine",
        "RedmineCredentialInjectorFilter"
      ],
      "handler": "RedmineProxy"
    }
  }
}
