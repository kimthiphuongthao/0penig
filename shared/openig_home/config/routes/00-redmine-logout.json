{
  "name": "00-redmine-logout-intercept",
  "condition": "${matches(request.headers['Host'][0], 'redmine-b.sso.local.*') and matches(request.uri.path, '^/logout$') and request.method == 'POST'}",
  "session": "SessionApp3",
  "heap": [
    {
      "name": "SessionApp3",
      "type": "JwtSession",
      "config": {
        "cookieName": "IG_SSO_APP3",
        "sessionTimeout": "30 minutes",
        "sharedSecret": "${env['JWT_SHARED_SECRET']}",
        "keystore": "JwtKeyStore",
        "alias": "openig-jwt",
        "password": "${env['KEYSTORE_PASSWORD']}"
      }
    }
  ],
  "handler": {
    "type": "Chain",
    "config": {
      "filters": [
        {
          "type": "ScriptableFilter",
          "config": {
            "type": "application/x-groovy",
            "file": "TokenReferenceFilter.groovy",
            "args": {
              "clientEndpoint": "/openid/app3",
              "redisHost": "shared-redis",
              "redisTtl": 1800,
              "tokenRefKey": "token_ref_id_app3",
              "redisUser": "openig-app3",
              "redisPasswordEnvVar": "REDIS_PASSWORD_APP3",
              "redisKeyPrefix": "app3",
              "transitKeyName": "app3-key",
              "appRoleName": "openig-app3",
              "vaultRoleIdFile": "/vault/file/openig-app3-role-id",
              "vaultSecretIdFile": "/vault/file/openig-app3-secret-id"
            }
          }
        }
      ],
      "handler": {
        "type": "ScriptableHandler",
        "config": {
          "type": "application/x-groovy",
          "file": "SloHandler.groovy",
          "args": {
            "clientEndpoint": "/openid/app3",
            "clientId": "openig-client-b",
            "canonicalOrigin": "http://redmine-b.sso.local",
            "postLogoutPath": "/",
            "redisHost": "shared-redis",
            "redisUser": "openig-app3",
            "redisPasswordEnvVar": "REDIS_PASSWORD_APP3",
            "redisKeyPrefix": "app3",
            "tokenRefKey": "token_ref_id_app3"
          }
        }
      }
    }
  }
}
