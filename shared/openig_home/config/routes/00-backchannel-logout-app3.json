{
  "name": "00-backchannel-logout-app3",
  "condition": "${matches(request.uri.path, '^/openid/app3/backchannel_logout$') and request.method == 'POST'}",
  "handler": {
    "type": "ScriptableHandler",
    "config": {
      "type": "application/x-groovy",
      "file": "BackchannelLogoutHandler.groovy",
      "args": {
        "audiences": [
          "openig-client-b"
        ],
        "redisHost": "shared-redis",
        "jwksUri": "http://host.docker.internal:8080/realms/sso-realm/protocol/openid-connect/certs",
        "issuer": "http://auth.sso.local:8080/realms/sso-realm",
        "ttlSeconds": "${env['REDIS_BLACKLIST_TTL_APP3'] != null ? env['REDIS_BLACKLIST_TTL_APP3'] : '28800'}",
        "redisUser": "openig-app3",
        "redisPasswordEnvVar": "REDIS_PASSWORD_APP3",
        "redisKeyPrefix": "app3"
      }
    }
  }
}
