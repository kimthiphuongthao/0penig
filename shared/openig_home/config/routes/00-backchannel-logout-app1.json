{
  "name": "00-backchannel-logout-app1",
  "condition": "${matches(request.uri.path, '^/openid/app1/backchannel_logout$') and request.method == 'POST'}",
  "handler": {
    "type": "ScriptableHandler",
    "config": {
      "type": "application/x-groovy",
      "file": "BackchannelLogoutHandler.groovy",
      "args": {
        "audiences": [
          "openig-client"
        ],
        "redisHost": "shared-redis",
        "jwksUri": "${env['KEYCLOAK_INTERNAL_URL']}/realms/sso-realm/protocol/openid-connect/certs",
        "issuer": "${env['KEYCLOAK_BROWSER_URL']}/realms/sso-realm",
        "ttlSeconds": "${env['REDIS_BLACKLIST_TTL'] != null ? env['REDIS_BLACKLIST_TTL'] : '28800'}",
        "redisUser": "openig-app1",
        "redisPasswordEnvVar": "REDIS_PASSWORD_APP1",
        "redisKeyPrefix": "app1"
      }
    }
  }
}
