{
  "name": "00-phpmyadmin-logout",
  "condition": "${request.headers['Host'] != null and request.headers['Host'][0] != null and matches(request.headers['Host'][0], '(?i)^phpmyadmin-c[.]sso[.]local(:[0-9]+)?$') and (((request.method == 'GET') and matches(request.uri.path, '^/$') and request.uri.query != null and matches(request.uri.query, '(^|&)logout=1($|&)')) or (((request.method == 'GET') or (request.method == 'POST')) and matches(request.uri.path, '^/index[.]php$') and request.uri.query != null and matches(request.uri.query, '(^|&)route=(/|%2[Ff])logout($|&)')))}",
  "handler": {
    "type": "Chain",
    "config": {
      "filters": [
        {
          "type": "ScriptableFilter",
          "config": {
            "type": "application/x-groovy",
            "file": "TokenReferenceFilter.groovy",
            "args": {
              "clientEndpoint": "/openid/app6",
              "redisHost": "shared-redis",
              "redisTtl": 1800,
              "tokenRefKey": "token_ref_id_app6",
              "sessionCacheKey": "oidc_sid_app6",
              "redisUser": "openig-app6",
              "redisPasswordEnvVar": "REDIS_PASSWORD_APP6",
              "redisKeyPrefix": "app6"
            }
          }
        }
      ],
      "handler": {
        "type": "ScriptableHandler",
        "config": {
          "type": "application/x-groovy",
          "file": "SloHandler.groovy",
          "args": {
            "clientEndpoint": "/openid/app6",
            "clientId": "openig-client-c-app6",
            "canonicalOrigin": "http://phpmyadmin-c.sso.local",
            "postLogoutPath": "/",
            "redisHost": "shared-redis",
            "redisUser": "openig-app6",
            "redisPasswordEnvVar": "REDIS_PASSWORD_APP6",
            "redisKeyPrefix": "app6",
            "tokenRefKey": "token_ref_id_app6"
          }
        }
      }
    }
  }
}
