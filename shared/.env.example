# Copy this file to .env and replace placeholders before running shared infrastructure.

OPENIG_PUBLIC_URL=http://openig.sso.local
KEYCLOAK_BROWSER_URL=http://auth.sso.local:8080
KEYCLOAK_INTERNAL_URL=http://host.docker.internal:8080

JWT_SHARED_SECRET=<base64-encoded-jwt-shared-secret>
KEYSTORE_PASSWORD=<openig-keystore-password>

OIDC_CLIENT_ID=openig-client
OIDC_CLIENT_SECRET=<keycloak-client-secret-for-openig-client>
OIDC_CLIENT_ID_B=openig-client-b
OIDC_CLIENT_SECRET_B=<keycloak-client-secret-for-openig-client-b>
OIDC_CLIENT_ID_APP4=openig-client-b-app4
OIDC_CLIENT_SECRET_APP4=<keycloak-client-secret-for-openig-client-b-app4>
OIDC_CLIENT_ID_APP5=openig-client-c-app5
OIDC_CLIENT_SECRET_APP5=<keycloak-client-secret-for-openig-client-c-app5>
OIDC_CLIENT_ID_APP6=openig-client-c-app6
OIDC_CLIENT_SECRET_APP6=<keycloak-client-secret-for-openig-client-c-app6>

REDIS_PORT=6379
REDIS_BACKCHANNEL_PORT=6379
REDIS_PASSWORD_APP1=change_me_redis_app1
REDIS_PASSWORD_APP2=change_me_redis_app2
REDIS_PASSWORD_APP3=change_me_redis_app3
REDIS_PASSWORD_APP4=change_me_redis_app4
REDIS_PASSWORD_APP5=change_me_redis_app5
REDIS_PASSWORD_APP6=change_me_redis_app6
REDIS_TTL_APP1=1800
REDIS_TTL_APP2=1800
REDIS_TTL_APP3=1800
REDIS_TTL_APP4=1800
REDIS_TTL_APP5=1800
REDIS_TTL_APP6=1800
REDIS_BLACKLIST_TTL_APP1=28800
REDIS_BLACKLIST_TTL_APP2=28800
REDIS_BLACKLIST_TTL_APP3=28800
REDIS_BLACKLIST_TTL_APP4=28800
REDIS_BLACKLIST_TTL_APP5=28800
REDIS_BLACKLIST_TTL_APP6=28800

CANONICAL_ORIGIN_APP1=http://wp-a.sso.local
CANONICAL_ORIGIN_APP2=http://whoami-a.sso.local
CANONICAL_ORIGIN_APP3=http://redmine-b.sso.local
CANONICAL_ORIGIN_APP4=http://jellyfin-b.sso.local
CANONICAL_ORIGIN_APP5=http://grafana-c.sso.local
CANONICAL_ORIGIN_APP6=http://phpmyadmin-c.sso.local

MYSQL_ROOT_PASSWORD_A=<mysql-root-password-for-wordpress-stack>
WORDPRESS_DB_PASSWORD=change_me_wordpress_db_password

MYSQL_ROOT_PASSWORD_B=<mysql-root-password-for-redmine-stack>
REDMINE_DB_PASSWORD=<redmine-database-password>
REDMINE_SECRET_KEY_BASE=<redmine-secret-key-base>

MYSQL_ROOT_PASSWORD_C=<mariadb-root-password-for-phpmyadmin-stack>
MYSQL_PASSWORD_C=change_me_mariadb_app_password

# Vault bootstrap application credentials
WP_ALICE_PASSWORD=change_me_alice_wp
WP_BOB_PASSWORD=change_me_bob_wp
REDMINE_ALICE_PASSWORD=change_me_alice_redmine
REDMINE_BOB_PASSWORD=change_me_bob_redmine
PHPMYADMIN_ALICE_PASSWORD=change_me_alice_phpmyadmin
PHPMYADMIN_BOB_PASSWORD=change_me_bob_phpmyadmin

# Real Jellyfin passwords must remain alphanumeric-only for form injection.
JELLYFIN_ALICE_PASSWORD=changeMeAliceJellyfin1
JELLYFIN_BOB_PASSWORD=changeMeBobJellyfin1

JELLYFIN_SERVER_ID=8a4467ecf1d4422583f472d90cb8c78f
TZ=Asia/Ho_Chi_Minh
