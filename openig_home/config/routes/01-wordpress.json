{
    "name": "wordpress-sso",
    "baseURI": "http://wordpress",
    "condition": "${not(matches(request.uri.path, '^/openig')) and not(matches(request.uri.path, '^/app2'))}",
    "heap": [
        {
            "name": "KeycloakIssuer",
            "type": "Issuer",
            "config": {
                "issuer": "http://localhost:8080/realms/sso-realm",
                "authorizeEndpoint": "http://localhost:8080/realms/sso-realm/protocol/openid-connect/auth",
                "tokenEndpoint": "http://keycloak:8080/realms/sso-realm/protocol/openid-connect/token",
                "userInfoEndpoint": "http://keycloak:8080/realms/sso-realm/protocol/openid-connect/userinfo",
                "registrationEndpoint": "http://keycloak:8080/realms/sso-realm/clients-registrations/openid-connect",
                "endSessionEndpoint": "http://localhost:8080/realms/sso-realm/protocol/openid-connect/logout"
            }
        },
        {
            "name": "OpenIGClientReg",
            "type": "ClientRegistration",
            "config": {
                "clientId": "openig-client",
                "clientSecret": "openig-client-secret",
                "issuer": "KeycloakIssuer",
                "scopes": [
                    "openid",
                    "profile",
                    "email"
                ]
            }
        },
        {
            "name": "OidcFilter",
            "type": "OAuth2ClientFilter",
            "config": {
                "clientEndpoint": "/openid",
                "requireHttps": false,
                "registrations": [
                    "OpenIGClientReg"
                ],
                "scopes": [
                    "openid",
                    "profile",
                    "email"
                ],
                "target": "${attributes.openid}",
                "defaultLogoutGoto": "http://localhost:8080/realms/sso-realm/protocol/openid-connect/logout?client_id=openig-client&post_logout_redirect_uri=http%3A%2F%2Flocalhost%2F",
                "failureHandler": {
                    "type": "StaticResponseHandler",
                    "config": {
                        "status": 500,
                        "reason": "Internal Server Error",
                        "headers": {
                            "Content-Type": [
                                "text/html"
                            ]
                        },
                        "entity": "<html><body><h2>SSO authentication failed. Please contact support.</h2></body></html>"
                    }
                }
            }
        },
        {
            "name": "VaultCredentialFilter",
            "type": "ScriptableFilter",
            "config": {
                "type": "application/x-groovy",
                "file": "VaultCredentialFilter.groovy"
            }
        },
        {
            "name": "WpSessionInjector",
            "type": "ScriptableFilter",
            "config": {
                "type": "application/x-groovy",
                "file": "CredentialInjector.groovy"
            }
        },
        {
            "name": "WordPressProxy",
            "type": "ClientHandler",
            "config": {
                "soTimeout": "10 seconds"
            }
        }
    ],
    "handler": {
        "type": "Chain",
        "config": {
            "filters": [
                "OidcFilter",
                "VaultCredentialFilter",
                "WpSessionInjector"
            ],
            "handler": "WordPressProxy"
        }
    }
}
